SLACK_ALLOWED_TEAM_ID=
SLACK_ALLOWED_ORG_ID=
# You can also provide comma-separated variants:
SLACK_ALLOWED_TEAM_IDS=
SLACK_ALLOWED_ORG_IDS=
# Optional legacy Google auth (only if you still need it)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
